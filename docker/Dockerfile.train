# Training image – runs train_model.py and writes artefacts to /app/model
# The model/ directory should be mounted as a volume so the host picks up outputs.
FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

COPY train_model.py .
COPY data/ data/

# Ensure output directory exists
RUN mkdir -p model

CMD ["python", "train_model.py"]
